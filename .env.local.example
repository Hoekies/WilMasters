# Kopieer dit bestand naar .env.local en vul je Firebase-waarden in.
# Vind deze waarden in Firebase Console → Project Settings → Je apps → Web

NEXT_PUBLIC_FIREBASE_API_KEY=jouw-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jouw-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=jouw-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=jouw-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
